{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/index",
      "permanent": true
    },
    {
      "source": "/docs/",
      "destination": "/docs/index",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "https://app.staplehire.com/login",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "https://app.staplehire.com/signup",
      "permanent": false
    },
    {
      "source": "/apply/:path*",
      "destination": "https://app.staplehire.com/apply/:path*",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://app.staplehire.com/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/share/:path*",
      "destination": "https://app.staplehire.com/share/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/docs/:match*",
      "destination": "https://staplehire.mintlify.dev/docs/:match*"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/((?!blog|docs|assets|landing|favicon|robots|sitemap|static-loader).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/landing/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
