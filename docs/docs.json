{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Staplehire CLI",
  "description": "Install, authenticate, and run the Staplehire CLI from your terminal or AI editor.",
  "colors": {
    "primary": "#FF6701",
    "light": "#FF7A1A",
    "dark": "#E55C00"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/@staplehire/staplehire-cli"
      },
      {
        "label": "Staplehire",
        "href": "https://staplehire.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install CLI",
      "href": "/installation"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/navindev26/staplehire-landing"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp", "vscode"],
    "display": "header"
  },
  "redirects": [
    { "source": "/quickstart", "destination": "/installation", "permanent": true },
    { "source": "/cli/overview", "destination": "/", "permanent": true },
    { "source": "/cli/installation", "destination": "/installation", "permanent": true },
    { "source": "/cli/commands", "destination": "/commands", "permanent": true },
    { "source": "/cli/ai-agents", "destination": "/ai-agents", "permanent": true }
  ],
  "navigation": {
    "groups": [
      {
        "group": "CLI",
        "icon": {
          "name": "terminal",
          "library": "lucide"
        },
        "pages": ["index", "installation", "commands", "ai-agents"]
      }
    ]
  }
}
