{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Staplehire CLI",
  "description": "Run hiring workflows from the terminal with the Staplehire CLI: create roles, source candidates, send AI interviews, enrich research, and automate everything with JSON output built for scripts and AI agents.",
  "colors": {
    "primary": "#FF6701",
    "light": "#FF7A1A",
    "dark": "#E55C00"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/@staplehire/staplehire-cli"
      },
      {
        "label": "Open app",
        "href": "https://app.staplehire.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install CLI",
      "href": "/installation"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/navindev26/Staplehire",
      "website": "https://staplehire.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp", "vscode"],
    "display": "header"
  },
  "redirects": [
    { "source": "/cli/overview", "destination": "/", "permanent": true },
    { "source": "/cli/installation", "destination": "/installation", "permanent": true },
    { "source": "/cli/commands", "destination": "/commands", "permanent": true },
    { "source": "/cli/ai-agents", "destination": "/ai-agents", "permanent": true }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "icon": { "name": "rocket", "library": "lucide" },
        "pages": [
          "index",
          "installation",
          "authentication",
          "quickstart"
        ]
      },
      {
        "group": "Workflows",
        "icon": { "name": "workflow", "library": "lucide" },
        "pages": [
          "create-role-cli",
          "stages-cli",
          "add-candidate-cli",
          "enrich-candidate-cli",
          "send-interview-cli",
          "send-email-cli",
          "source-candidates-cli",
          "search-cli",
          "poll-agent-jobs"
        ]
      },
      {
        "group": "Automation",
        "icon": { "name": "bot", "library": "lucide" },
        "pages": [
          "ai-agents",
          "use-staplehire-cli-in-ci"
        ]
      },
      {
        "group": "Reference",
        "icon": { "name": "book-open", "library": "lucide" },
        "pages": [
          "commands",
          "cli-errors"
        ]
      }
    ]
  }
}
